      <aliases enabled='yes' />
      <column caption='Chronic Status' datatype='string' name='[Calculation_2501397805281153024]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [chronic_condition_flag] = 1 THEN &quot;Chronic Condition&quot;&#10;ELSE &quot;No Chronic Condition&quot;&#10;END' />
      </column>
      <column caption='% Chronic' datatype='real' name='[Calculation_2501397805463781378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([chronic_condition_flag]) / COUNT([employee_id])' />
      </column>
      <column caption='% Dependents' datatype='real' name='[Calculation_2501397805466406915]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IIF([dependents_count] &gt; 0, 1, 0)) / COUNT([employee_id])' />
      </column>
